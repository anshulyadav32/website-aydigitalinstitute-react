# Environment Variables
# Copy this file to .env and update with your values

# Server
PORT=5000
NODE_ENV=development

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aydigital
DB_USER=postgres
DB_PASSWORD=postgres
# Or use connection string format:
# DATABASE_URL=postgresql://username:password@localhost:5432/aydigital

# JWT Secret (Change this to a strong random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Cloudflare R2 Storage
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=aydigital
R2_PUBLIC_URL=https://your-custom-r2-domain.com
